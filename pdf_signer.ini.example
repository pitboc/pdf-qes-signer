# PDF QES Signer – example configuration
#
# The application stores its configuration in two locations:
#
#   ~/.config/pdf-signer/settings.ini          ← global settings (language, active profile)
#   ~/.config/pdf-signer/profiles/default.ini  ← profile settings (signing, appearance, …)
#
# Both files are created automatically on first run.
# Additional profiles are stored as ~/.config/pdf-signer/profiles/<name>.ini
#
# If an old single-file ~/.config/pdf-signer/pdf_signer.ini exists, it is
# migrated automatically on first start and renamed to pdf_signer.ini.migrated.


# ── ~/.config/pdf-signer/settings.ini ────────────────────────────────────────

[app]
# UI language: de | en
language = de
# Name of the active profile (must match a file in profiles/)
active_profile = default

[validation]
# Fetch missing OCSP responses from the network when checking signatures:
#   always – fetch when not embedded in the PDF
#   never  – use only data already present in the PDF
auto_fetch_revocation = always


# ── ~/.config/pdf-signer/profiles/default.ini ────────────────────────────────

[pkcs11]
# Signing mode: pkcs11 (hardware token) | pfx (PKCS#12 file)
signer_mode = pkcs11
# Full path to your PKCS#11 library (pkcs11 mode only)
lib_path = /usr/lib/x86_64-linux-gnu/opensc-pkcs11.so
# Hex CKA_ID of the private key (filled automatically by the token test dialog)
key_id =
# Certificate subject CN (filled automatically by the token test dialog)
cert_cn =
# Path to a PFX/PKCS#12 file (pfx mode only)
pfx_path =

[paths]
# Directories remembered between sessions (filled automatically)
last_open_dir = ~
last_lib_dir  = /usr/lib
last_img_dir  = ~

[tsa]
# Enable RFC 3161 timestamp (1 = enabled, 0 = disabled)
enabled = 0
# TSA service URL
url = http://tsa.baltstamp.lt
# Embed OCSP revocation data and archival timestamp (PAdES-LTA); requires TSA
embed_validation_info = 0

[signing]
# docMDP: document modification policy for the first (certifying) signature.
# Shown as a dialog when applying the first signature; value is the last choice.
#   none – no restriction (no certify flag)
#   p2   – form fields and further signatures allowed (recommended)
#   p1   – no changes allowed after signing
docmdp = none

[appearance]
# Absolute path to a PNG image shown in the signature field (optional)
image_path =
# Image position: img_left | img_right
layout = img_left
# Show / hide text elements (1 = show, 0 = hide)
show_location = 1
location =
show_reason = 1
reason =
show_name = 1
# Name source: cert (from certificate CN) | custom
name_mode = cert
name_custom =
show_date = 1
# strftime format string
date_format = %%d.%%m.%%Y %%H:%%M
# Font size in PDF points
font_size = 8
# PDF-14 font name: Helvetica | Helvetica-Bold | Times-Roman | Courier | …
font_family = Helvetica
# Draw a border around the signature field (1 | 0)
show_border = 1
# Percentage of field width occupied by the image (10–70)
img_ratio = 40
